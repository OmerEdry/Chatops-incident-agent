# ─── App Configuration ────────────────────────────────────────────────────────
APP_NAME=ChatOps Incident Agent
APP_ENVIRONMENT=development   # development | staging | production
APP_DEBUG=False

# ─── LLM API Keys ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/your_long_token_here" #open discord server, under server settings/integrations/webhooks

# ─── PostgreSQL Connection Parameters ─────────────────────────────────────────
# When connecting to the docker-compose db service, use DB_HOST=db (service name).
# For local (non-Docker) development, use DB_HOST=localhost.
DB_HOST=localhost
DB_PORT=5433
DB_USER=chatops_user
DB_PASSWORD=chatops_password
DB_NAME=chatops_db
