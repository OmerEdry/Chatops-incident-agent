# ─── App Configuration ────────────────────────────────────────────────────────
APP_NAME=ChatOps Incident Agent
APP_ENVIRONMENT=development   # development | staging | production
APP_DEBUG=False

# ─── LLM API Keys ─────────────────────────────────────────────────────────────
